{
  "expo": {
    "name": "HereNow",
    "slug": "herenow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "herenow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gilgameshenterprise.herenow",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HereNow uses your location to show you zones nearby and let you join them.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HereNow uses your location in the background to notify you when you enter or leave a zone.",
        "NSLocationAlwaysUsageDescription": "HereNow uses your location in the background to notify you when you enter or leave a zone.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#050A15"
      },
      "package": "com.gilgameshenterprise.herenow",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "HereNow",
      "shortName": "HereNow",
      "description": "Connect where you are. Check in to venues, meet people IRL, and see who's out tonight.",
      "backgroundColor": "#050A15",
      "themeColor": "#29B6F6",
      "lang": "en",
      "display": "standalone",
      "startUrl": "/",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HereNow uses your location to show nearby zones and notify you when you enter one.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
