{
  "expo": {
    "name": "HereNow",
    "slug": "jbost",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "herenow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gilgameshenterprise.herenow",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HereNow uses your location to show you zones nearby and let you join them.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "HereNow uses your location in the background to notify you when you enter or leave a zone.",
        "NSLocationAlwaysUsageDescription": "HereNow uses your location in the background to notify you when you enter or leave a zone.",
        "NSPhotoLibraryUsageDescription": "HereNow lets venue owners add photos to announcements and events.",
        "NSCameraUsageDescription": "HereNow lets you take a photo for your profile or attach one to an announcement.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#050A15"
      },
      "package": "com.gilgameshenterprise.herenow",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "HereNow",
      "shortName": "HereNow",
      "description": "Connect where you are. Check in to venues, meet people IRL, and see who's out tonight.",
      "backgroundColor": "#050A15",
      "themeColor": "#29B6F6",
      "lang": "en",
      "display": "standalone",
      "startUrl": "/",
      "orientation": "portrait"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "HereNow uses your location to show nearby zones and notify you when you enter one.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#050A15",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "HereNow lets venue owners add photos to announcements and events.",
          "cameraPermission": "HereNow lets you take a photo for your profile or attach one to an announcement."
        }
      ],
      "expo-build-properties",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "961a1251-c044-441c-802e-1e3f7711bcf4"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "gilgameshenterprisellc"
  }
}
